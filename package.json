{
	"name": "bun-clean-architecture-starter",
	"version": "1.0.0",
	"description": "Production-ready TypeScript starter template with Clean Architecture, DDD, Bun runtime, Kysely ORM, and PostgreSQL",
	"author": "Your Name <your.email@example.com>",
	"license": "MIT",
	"type": "module",
	"private": false,
	"keywords": [
		"typescript",
		"bun",
		"clean-architecture",
		"ddd",
		"starter-template",
		"boilerplate",
		"kysely",
		"postgresql",
		"dependency-injection",
		"awilix"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/yourusername/bun-clean-architecture-starter"
	},
	"bugs": {
		"url": "https://github.com/yourusername/bun-clean-architecture-starter/issues"
	},
	"homepage": "https://github.com/yourusername/bun-clean-architecture-starter#readme",
	"scripts": {
		"dev": "bun --hot ./src/index.ts",
		"start": "bun ./src/index.ts",
		"build": "bun build ./src/index.ts --outdir ./dist --target bun",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format . --write",
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"clean": "rm -rf dist .bun node_modules"
	},
	"devDependencies": {
		"@types/bun": "^1.3.6",
		"@types/lodash-es": "^4.17.12"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@loglayer/transport-pino": "^2.2.17",
		"@trpc/server": "^11.8.1",
		"awilix": "^12.0.5",
		"bun-types": "^1.3.9",
		"dayjs": "^1.11.19",
		"inngest": "^3.49.3",
		"kysely": "^0.28.11",
		"lodash-es": "^4.17.23",
		"loglayer": "^8.4.0",
		"pg": "^8.17.2",
		"pino": "^10.3.0",
		"pino-pretty": "^13.1.3",
		"serialize-error": "^13.0.1",
		"zod": "^4.3.6"
	}
}
